generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workflow {
  id              String   @id
  nodes           Json
  edges           Json
  runHistory      Json
  recentNodeTypes Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}